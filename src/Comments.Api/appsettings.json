      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Captcha": {
    "Enabled": true,
    "Provider": "Basic",
    "ExpectedToken": "",
    "VerifyEndpoint": "https://www.google.com/recaptcha/api/siteverify",
    "SecretKey": ""
