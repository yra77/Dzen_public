{
  "Persistence": {
    "Provider": "InMemory"
  },
  "RabbitMq": {
    "Enabled": false,
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "ExchangeName": "comments.events",
    "RoutingKey": "comment.created",
    "IndexingQueueName": "indexing",
    "FileProcessingQueueName": "file-processing",
    "IndexingRoutingKey": "comment.created.indexing",
    "FileProcessingRoutingKey": "comment.created.file-processing",
    "ConsumerEnabled": true,
    "DeadLetterExchangeName": "comments.events.dlx",
    "DeadLetterQueueSuffix": ".dlq",
    "RetryHeaderName": "x-retry-count",
    "MaxRetryCount": 3
  },
  "ConnectionStrings": {
    "CommentsDb": "Server=localhost;Database=CommentsDb;User Id=sa;Password=Your_password123;TrustServerCertificate=True"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Captcha": {
    "Enabled": true,
    "Provider": "Basic",
    "ExpectedToken": "1234",
    "VerifyEndpoint": "https://www.google.com/recaptcha/api/siteverify",
    "SecretKey": ""
  },
  "Attachments": {
    "RootPath": "uploads",
    "MaxSizeBytes": 1048576,
    "MaxTextSizeBytes": 102400,
    "MaxImageWidth": 320,
    "MaxImageHeight": 240
  },
  "SignalR": {
    "Enabled": false
  },
  "Elasticsearch": {
    "Enabled": false,
    "Uri": "http://localhost:9200",
    "IndexName": "comments",
    "BackfillOnStartup": true
  }
}
