{
  "Persistence": {
    "Provider": "Sqlite"
  },
  "RabbitMq": {
    "Enabled": false,
    "HostName": "192.168.0.106",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "ExchangeName": "comments.events",
    "RoutingKey": "comment.created",
